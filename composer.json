{
    "name": "your-org/base-app",
    "type": "project",
    "description": "Template for Web Apps with PHP, Laravel and Vue",
    "version": "1.0.0",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "basis-company/nats": "^1.1",
        "laravel/framework": "^12.0",
        "laravel/mcp": "^0.3.4",
        "laravel/octane": "^2.12",
        "laravel/passport": "^13.1",
        "laravel/pennant": "^1.7",
        "laravel/reverb": "^1.2.0",
        "laravel/socialite": "^5.20",
        "laravel/tinker": "^2.10.1",
        "php-amqplib/php-amqplib": "v3.7.4",
        "pusher/pusher-php-server": "^7.2",
        "sentry/sentry-laravel": "^4.3",
        "socialiteproviders/laravelpassport": "^4.3",
        "spatie/laravel-health": "^1.29",
        "spatie/laravel-permission": "^7.2",
        "symfony/http-client": "^7.0",
        "symfony/postmark-mailer": "^8.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^1.8",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "tests/Feature/WaApiWebhookTest.php",
            "tests/Unit/Traits/",
            "tests/Unit/Policies/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:coverage": [
            "@php artisan config:clear --ansi",
            "@php artisan test --coverage"
        ],
        "test:coverage:check": [
            "@php artisan config:clear --ansi",
            "@php artisan test --coverage --min=80"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
